# Required for Athena (Groq). Set the same name in Vercel → Project → Settings → Environment Variables.
# Note: VITE_* variables are bundled into the browser — do not treat this as a secret in production.
VITE_GROQ_API_KEY=your-groq-api-key-here

# Optional: log analytics events in dev
# VITE_ANALYTICS_DEBUG=true
